# Copy this file to .env and fill in ONE of the following keys.
# Priority: GITHUB_TOKEN > OPENROUTER_API_KEY > OPENAI_API_KEY

# Option 1 — GitHub Models (free tier, OpenAI-compatible)
# Generate at: https://github.com/settings/tokens  (no special scopes needed)
GITHUB_TOKEN=ghp_yourGithubPatHere
OPENAI_BASE_URL=https://models.inference.ai.azure.com
MODEL_NAME=gpt-4o-mini

# Option 2 — OpenRouter (free models available)
# OPENROUTER_API_KEY=sk-or-...your-key-here...

# Option 3 — Standard OpenAI
# OPENAI_API_KEY=sk-...your-key-here...
